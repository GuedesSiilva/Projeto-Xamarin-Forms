<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="MauiApp1.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:MauiApp1"
    Title="Menu">

    <ShellContent
        Title="Menu"
        ContentTemplate="{DataTemplate local:TelaLogado}"
        Route="MainPage" />
    <FlyoutItem Title="Ir para Ranking Page">
        <ShellContent ContentTemplate="{DataTemplate local:RankingPage}"/>
    </FlyoutItem>
    <FlyoutItem Title="Ir para Abbout Page">
        <ShellContent ContentTemplate="{DataTemplate local:AbboutPage}"/>
    </FlyoutItem>


</Shell>
