<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp1.RankingPage"
             Title="RankingPage">
    <VerticalStackLayout Padding="25">
        <Label 
            Text="Ranking Participantes"
            HorizontalOptions="Center" />

        <CollectionView ItemsSource="{Binding ListaRanking}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <StackLayout Margin="0,25,0,0" Orientation="Horizontal">
                        <Label Text="{Binding Nome}"/>
                        <Label HorizontalOptions="EndAndExpand" Text="{Binding Pontos}"/>
                    </StackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentPage>